# ============================================================
# Premium Lead System — Environment Variables (Template)
# ============================================================
# העתק קובץ זה ל-.env מקומי וב-Vercel הגדר ב-Project Settings → Env Vars.
# אל תכניס את .env לקוד הפומבי!

# ----- מסד נתונים -----
# בלוקאל: SQLite (קובץ מקומי)
# DATABASE_URL="file:./dev.db"
#
# בייצור (Vercel + Neon/Supabase): Postgres URL
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DATABASE_URL="file:./dev.db"

# ----- NextAuth -----
# סוד חתימה ל-JWT. ייצר ערך אקראי חזק ל-production:
#   openssl rand -base64 32
# או באתר: https://generate-secret.vercel.app/32
AUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_BASE64"

# כתובת בסיס לאתר.
# בלוקאל: http://localhost:3000
# בייצור: https://yourdomain.com  (או https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
